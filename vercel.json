{
  "version": 2,
  "builds": [
    {
      "src": "api/express-app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "data/**",
          "public/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/express-app.js"
    }
  ]
}