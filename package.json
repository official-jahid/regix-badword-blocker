    "@discordjs/formatters": "^0.6.2",
    "@discordjs/next": "^0.1.1-dev.1673526225-a580768.0",
    "@discordjs/proxy": "^2.1.1",
    "@discordjs/rest": "^2.6.3",
    "@discordjs/structures": "^0.2.0-dev.1752365789-3cff4d741",
    "@discordjs/util": "^1.2.0",
    "@discordjs/voice": "^0.19.2",
    "@discordjs/ws": "^2.0.4",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "discord-api-types": "^0.38.50",
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "uuid": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.10",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.8.0",
    "typescript": "^5.5.4"
  }
