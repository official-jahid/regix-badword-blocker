{
  "name": "regix-badword-blocker",
  "version": "3.0.0",
  "description": "REGIX 🔥 GOD MODE - Advanced Discord Moderation Bot with Three.js 3D Web Dashboard",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "echo 'Vercel build complete'",
    "dashboard": "bun run api/server.js",
    "dashboard:dev": "bun --watch api/server.js",
    "dev:all": "concurrently \"bun run src/index.ts\" \"bun run api/server.js\"",
    "vercel-build": "echo 'Vercel build complete'",
    "lint": "eslint public/pages/**/*.js --fix"
  },
  "dependencies": {
    "@openrouter/agent": "^0.7.2",
    "@openrouter/sdk": "^0.13.60",
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "discord.js": "^14.16.3",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "three": "^0.170.0",
    "openai": "^6.48.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.10",
    "@types/node": "^22.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4"
  }
}
