  "description": "REGIX Bad Word Blocker — Discord moderation bot for filtering inappropriate language with real-time word detection and management",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "auth-server": "bun run src/auth-server.ts",
    "auth-server:dev": "bun --watch run src/auth-server.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@discordjs/brokers": "^1.0.0",
    "@discordjs/builders": "^1.14.1",
    "@discordjs/collection": "^2.1.1",
