# ─── Discord Bot ───────────────────────────────────────────────────────────
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_id_here
GUILD_ID=your_guild_id_here        # (optional) For instant slash deploy

# ─── Owner / Admin Configuration ──────────────────────────────────────────
# Discord user ID of the bot owner (full bypass + command access)
OWNER_ID=
# Role IDs for command authorization (any one grants access)
OWNER_ROLE_ID=
MOD_ROLE_ID=
ADMIN_ROLE_ID=

# ─── Log Channel ──────────────────────────────────────────────────────────
# Channel ID where moderation actions (deletions, strikes, bans) are logged
LOG_CHANNEL_ID=

# ─── OpenRouter AI (Moderation + Word Discovery) ─────────────────────────
# Uses OpenAI SDK pointed at OpenRouter: https://openrouter.ai/docs/quick-start
OPENROUTER_API_KEY=

# ─── Bot Prefix (optional, default: "!") ──────────────────────────────────
PREFIX=!

# ─── Prisma / Neon PostgreSQL ─────────────────────────────────────────────
# Connection string for Prisma/Neon PostgreSQL database
# Format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# ─── Auth Validation Server ───────────────────────────────────────────────
# Port for the standalone Express auth validation server (default: 4000)
AUTH_SERVER_PORT=4000

# ─── JWT Configuration ────────────────────────────────────────────────────
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here_change_this_in_production
# JWT token expiration time (default: 24h)
JWT_EXPIRES_IN=24h